# Database (Neon PostgreSQL — use the direct connection URL, not the pooler)
DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>?sslmode=require

# Server
PORT=5001
NODE_ENV=development

# JWT — must be at least 32 characters, cryptographically random
JWT_SECRET=change_me_to_a_random_32_char_string
JWT_EXPIRES_IN=7d

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif

# AWS S3 (file uploads)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Bcrypt cost factor (10-12 recommended for production)
BCRYPT_ROUNDS=10

# Backend public URL (used in Swagger docs and for internal reference)
BACKEND_URL=http://localhost:5001

# Redis (optional — from Upstash: upstash.com → Create Database → copy Redis URL)
REDIS_URL=rediss://:<password>@<host>:<port>
